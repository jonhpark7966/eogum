# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Optional legacy setting. The API verifies Supabase tokens via JWKS (ES256).
SUPABASE_JWT_SECRET=

# Admin access (comma-separated). Prefer ADMIN_EMAILS for quick setup.
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=eogum
R2_PUBLIC_URL=https://r2.eogum.sudoremove.com

# AVID (auto-video-edit)
# Eogum uses the sibling auto-video-edit checkout as the canonical avid runtime.
AVID_BACKEND_ROOT=/home/jonhpark/workspace/auto-video-edit/apps/backend
AVID_BIN=/home/jonhpark/workspace/auto-video-edit/apps/backend/.venv/bin/avid-cli
AVID_PROVIDER=codex
AVID_PROVIDER_MODEL=gpt-5.5
AVID_PROVIDER_EFFORT=xhigh
AVID_TEMP_DIR=/tmp/eogum
AVID_OUTPUT_DIR=/tmp/eogum/outputs

# Chalna
CHALNA_URL=http://localhost:7861

# Tools
YT_DLP_BIN=/home/jonhpark/.local/bin/yt-dlp

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@sudoremove.com

# Server
HOST=0.0.0.0
PORT=8000
