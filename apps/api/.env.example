# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Optional legacy setting. The API verifies Supabase tokens via JWKS (ES256).
SUPABASE_JWT_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=eogum
R2_PUBLIC_URL=https://r2.eogum.sudoremove.com

# AVID (auto-video-edit)
# Prefer the eogum submodule layout. `AVID_BIN` should point to the explicit CLI binary.
AVID_BACKEND_ROOT=/home/jonhpark/workspace/eogum/third_party/auto-video-edit/apps/backend
AVID_BIN=/home/jonhpark/workspace/eogum/third_party/auto-video-edit/apps/backend/.venv/bin/avid-cli
AVID_PROVIDER=codex
AVID_PROVIDER_MODEL=gpt-5.4
AVID_PROVIDER_EFFORT=medium
# Legacy fallback for pre-submodule local setups:
# AVID_CLI_PATH=/home/jonhpark/workspace/auto-video-edit/apps/backend
AVID_TEMP_DIR=/tmp/eogum
AVID_OUTPUT_DIR=/tmp/eogum/outputs

# Chalna
CHALNA_URL=http://localhost:7861

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@sudoremove.com

# Server
HOST=0.0.0.0
PORT=8000
